<Window
    x:Class="AmongUsModManager.Pages.DebugConsoleWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Debug Console">

    <Grid Background="#1E1E1E" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <Grid Grid.Row="0" Background="#2D2D2D" Padding="8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ToggleButton x:Name="BtnTrace" Grid.Column="0" Content="Trace"
                          IsChecked="False" Click="FilterChanged"
                          FontSize="11" Padding="6,3"
                          Background="#3A3A3A" Foreground="#AAAAAA"
                          BorderThickness="0" CornerRadius="3"/>
            <ToggleButton x:Name="BtnDebug" Grid.Column="2" Content="Debug"
                          IsChecked="False" Click="FilterChanged"
                          FontSize="11" Padding="6,3"
                          Background="#3A3A3A" Foreground="#569CD6"
                          BorderThickness="0" CornerRadius="3"/>
            <ToggleButton x:Name="BtnInfo" Grid.Column="4" Content="Info"
                          IsChecked="True" Click="FilterChanged"
                          FontSize="11" Padding="6,3"
                          Background="#3A3A3A" Foreground="#4EC9B0"
                          BorderThickness="0" CornerRadius="3"/>
            <ToggleButton x:Name="BtnWarn" Grid.Column="6" Content="Warn"
                          IsChecked="True" Click="FilterChanged"
                          FontSize="11" Padding="6,3"
                          Background="#3A3A3A" Foreground="#CE9178"
                          BorderThickness="0" CornerRadius="3"/>
            <ToggleButton x:Name="BtnError" Grid.Column="8" Content="Error"
                          IsChecked="True" Click="FilterChanged"
                          FontSize="11" Padding="6,3"
                          Background="#3A3A3A" Foreground="#F44747"
                          BorderThickness="0" CornerRadius="3"/>

            <TextBlock x:Name="CountText" Grid.Column="10"
                       VerticalAlignment="Center"
                       FontSize="11" Foreground="#666666"/>

            <Button x:Name="BtnClear" Grid.Column="12" Content="Clear"
                    Click="BtnClear_Click"
                    FontSize="11" Padding="8,3"
                    Background="#3A3A3A" Foreground="#CCCCCC"
                    BorderThickness="0" CornerRadius="3"/>
        </Grid>

        <!-- ログ表示 -->
        <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,0,0">
            <ItemsControl x:Name="LogItemsControl" Padding="4,4,4,48">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}"
                                   Foreground="{Binding Foreground}"
                                   FontFamily="Consolas, Cascadia Code, Courier New"
                                   FontSize="11.5"
                                   TextWrapping="NoWrap"
                                   Padding="4,1"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Background="#007ACC" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Text="Ready" FontSize="11"
                           Foreground="White" VerticalAlignment="Center"/>
                <ToggleButton x:Name="BtnAutoScroll" Grid.Column="1"
                              Content="Auto Scroll" IsChecked="True"
                              FontSize="11" Padding="6,2"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
