<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AmongUsModManager.Pages.ModInstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AmongUsModManager.Pages"
    xmlns:models="using:AmongUsModManager.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <Page.Resources>
        <models:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
        <models:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <models:BoolToBlackBrushConverter        x:Key="BoolToBlackBrushConverter"/>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="10" Margin="0,0,0,16">
            <Grid>
                <TextBlock Text="Modインストール" FontSize="24" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="6"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ToggleButton x:Name="LayoutToggleBtn"
                                  ToolTipService.ToolTip="グリッド／リスト 切り替え"
                                  Checked="LayoutToggle_Checked"
                                  Unchecked="LayoutToggle_Unchecked"
                                  Padding="8,6">
                        <FontIcon x:Name="LayoutToggleIcon" Glyph="&#xE8FD;" FontSize="16"/>
                    </ToggleButton>
                    <ToggleButton x:Name="DetailPosToggleBtn"
                                  ToolTipService.ToolTip="詳細パネルを下／右 切り替え"
                                  Checked="DetailPosToggle_Checked"
                                  Unchecked="DetailPosToggle_Unchecked"
                                  Padding="8,6">
                        <FontIcon x:Name="DetailPosIcon" Glyph="&#xE951;" FontSize="16"/>
                    </ToggleButton>
                </StackPanel>
            </Grid>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="GitHubUrlBox"
                         PlaceholderText="GitHub URL (https://github.com/...) または 共有コード (AUMM-...)"/>
                <Button Grid.Column="1" Content="URLから取得" Click="GitHubFetch_Click"/>
                <Button Grid.Column="2" Content="📂 .aumanagerを開く" Click="OpenAumanager_Click"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="🗜️ ZIPファイルから直接インストール" Click="InstallFromZip_Click"/>
                <Button Content="🔗 直接DLリンクからインストール"   Click="InstallFromDirectUrl_Click"/>
            </StackPanel>

            <TextBox x:Name="ModSearchBox"
                     PlaceholderText="🔍 Modを検索..."
                     TextChanged="ModSearchBox_TextChanged"/>
        </StackPanel>

        <Grid x:Name="ContentGrid" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="DetailRow" Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="DetailCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                          CornerRadius="8">

                <GridView x:Name="ModGridView" Padding="15"
                          SelectionChanged="ModGridView_SelectionChanged">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:ModPreset">
                            <Border Width="180" Margin="5" CornerRadius="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Border Height="100" CornerRadius="10,10,0,0"
                                            Background="{x:Bind DarkBackground, Converter={StaticResource BoolToBlackBrushConverter}}">
                                        <Border.Clip>
                                            <RectangleGeometry Rect="0,0,180,100"/>
                                        </Border.Clip>
                                        <Grid>
                                            <Image Source="{x:Bind ThumbnailUrl}"
                                                   Stretch="{x:Bind ImageStretch}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   MaxHeight="100" MaxWidth="180"
                                                   Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                                                    Visibility="{x:Bind HasThumbnail, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <SymbolIcon Symbol="Library" Foreground="White" Margin="10"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel Padding="10,8,10,10" Spacing="3">
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind Description}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" MaxLines="2"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </ScrollViewer>

            <ListView x:Name="ModListView" Visibility="Collapsed"
                      Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                      CornerRadius="8" Padding="8"
                      SelectionChanged="ModListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ModPreset">
                        <Grid Padding="8,10" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="64" Height="40" CornerRadius="6"
                                    Background="{x:Bind DarkBackground, Converter={StaticResource BoolToBlackBrushConverter}}">
                                <Grid>
                                    <Image Source="{x:Bind ThumbnailUrl}"
                                           Stretch="Uniform"
                                           Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                                            Visibility="{x:Bind HasThumbnail, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <SymbolIcon Symbol="Library" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}"
                                           FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{x:Bind Description}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border x:Name="InstallDetailArea"
                    Grid.Row="1" Grid.Column="0"
                    Visibility="Collapsed"
                    Padding="20" Margin="0,12,0,0" CornerRadius="12"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                <Grid>
                    <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressRing IsActive="True" Margin="0,0,0,10"/>
                        <TextBlock Text="GitHubからデータを取得中..."/>
                    </StackPanel>

                    <ScrollViewer x:Name="SelectionPanel" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock x:Name="SelectedModTitle" Text=""
                                           FontSize="20" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="CloseDetailBtn"
                                        Content="✕ 閉じる"
                                        HorizontalAlignment="Right"
                                        Click="CloseDetail_Click"
                                        Padding="10,5"/>
                            </Grid>

                            <TextBlock x:Name="SelectedModDescription"
                                       Text="" FontSize="13"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="Collapsed"/>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="VersionCombo" Header="バージョン"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="VersionCombo_SelectionChanged"/>
                                <ComboBox Grid.Column="1" x:Name="AssetCombo" Header="ファイル (Zip)"
                                          HorizontalAlignment="Stretch"/>
                            </Grid>
                            <TextBox x:Name="InstallFolderName"
                                     Header="インストール後のフォルダ名"
                                     PlaceholderText="例: TownOfHost_v1.0.0"/>
                            <Button Content="インストールを実行"
                                    HorizontalAlignment="Stretch" Height="45"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="StartInstall_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
