<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AmongUsModManager.Pages.DataManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AmongUsModManager.Models"
    xmlns:local="using:AmongUsModManager.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <models:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Margin="28,20,28,32">

            <TextBlock Text="データ管理" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Text="フレンドコード・バンリストを管理します"
                       FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,-8,0,0"/>

            <TabView x:Name="DataTabView"
                     IsAddTabButtonVisible="False"
                     TabWidthMode="Equal">

                
                <TabViewItem Header="フレンドコード" IconSource="{x:Null}">
                    <ScrollViewer Padding="0,12,0,0">
                        <StackPanel Spacing="12">
                            <RelativePanel>
                                <TextBlock Text="フレンドコードのメモ"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Content="＋ 追加"
                                        RelativePanel.AlignRightWithPanel="True"
                                        Click="AddFriend_Click"/>
                            </RelativePanel>

                            <ListView x:Name="FriendListView" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FriendEntry">
                                        <Grid ColumnDefinitions="*, Auto, Auto, Auto"
                                              ColumnSpacing="8" Padding="12,10"
                                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                              CornerRadius="6">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{x:Bind Code}" FontFamily="Consolas" FontSize="12"
                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{x:Bind Memo}" FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Visibility="{x:Bind Memo, Converter={StaticResource StringToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="コピー"
                                                    Tag="{x:Bind Code}" Click="CopyCode_Click"
                                                    Padding="8,4"/>
                                            <Button Grid.Column="2" Content="編集"
                                                    Tag="{x:Bind}" Click="EditFriend_Click"
                                                    Padding="8,4"/>
                                            <Button Grid.Column="3" Content="削除"
                                                    Tag="{x:Bind}" Click="DeleteFriend_Click"
                                                    Padding="8,4" Foreground="Tomato"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock x:Name="FriendEmptyText"
                                       Text="フレンドコードが登録されていません"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="13" HorizontalAlignment="Center"
                                       Margin="0,16" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

                
                <TabViewItem Header="バンリスト" IconSource="{x:Null}">
                    <ScrollViewer Padding="0,12,0,0">
                        <StackPanel Spacing="12">

                            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                     Title="Modごとのバンリスト"
                                     Message="各ModフォルダのBanList.txtを自動で読み込みます。編集した内容はファイルに直接保存されます。"/>

                            
                            <ComboBox x:Name="BanModSelector" Header="対象Mod"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Modを選択してください"
                                      SelectionChanged="BanModSelector_SelectionChanged"/>

                            <RelativePanel>
                                <TextBlock x:Name="BanFilePathText"
                                           Text=""
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            RelativePanel.AlignRightWithPanel="True">
                                    <Button Content="更新"
                                            Click="RefreshBanList_Click"/>
                                    <Button Content="＋ 追加"
                                            Click="AddBan_Click"/>
                                </StackPanel>
                            </RelativePanel>

                            <ListView x:Name="BanListView" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:BanListEntry">
                                        <Grid ColumnDefinitions="*, Auto"
                                              ColumnSpacing="8" Padding="12,10"
                                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                              CornerRadius="6">
                                            <TextBlock Text="{x:Bind Code}"
                                                       FontFamily="Consolas" FontSize="13"
                                                       Foreground="Tomato"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="削除"
                                                    Tag="{x:Bind}" Click="DeleteBanEntry_Click"
                                                    Padding="8,4" Foreground="Tomato"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock x:Name="BanEmptyText"
                                       Text="Modを選択するか、BanList.txtが存在しません"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="13" HorizontalAlignment="Center"
                                       Margin="0,16" Visibility="Visible"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

                
                <TabViewItem Header="多言語化パッチ" IconSource="{x:Null}">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Spacing="16" MaxWidth="400" Padding="24">
                            <FontIcon Glyph="&#xF2B7;" FontSize="48"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center"/>
                            <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                    CornerRadius="8" Padding="16,12">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="🚧  開発中" FontSize="15" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="多言語化パッチ機能は現在開発中です。&#x0a;今後のアップデートで対応予定です。"
                                               TextWrapping="Wrap" FontSize="12" TextAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabViewItem>

            </TabView>
        </StackPanel>
    </ScrollViewer>
</Page>
