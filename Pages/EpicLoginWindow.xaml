<Window
    x:Class="AmongUsModManager.EpicLoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Login to Epic Games">

    <Grid>
        <Border x:Name="LoadingOverlay"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="40" Height="40"/>
                <TextBlock Text="Epic Games ログインページを読み込み中..."
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <WebView2
            x:Name="LoginWebView"
            Visibility="Collapsed"
            NavigationStarting="LoginWebView_NavigationStarting"
            NavigationCompleted="LoginWebView_NavigationCompleted"/>
    </Grid>
</Window>
