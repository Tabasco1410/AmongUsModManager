<Page
    x:Class="AmongUsModManager.Pages.VersionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="using:AmongUsModManager.Models.Services"
    xmlns:local="using:AmongUsModManager.Pages"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Spacing="8" Margin="0,0,0,24">
            <TextBlock Text="バージョン管理" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="過去のバージョンに切り替えることができます。"
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
        </StackPanel>
        <ListView x:Name="VersionListView" Grid.Row="1" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="services:UpdateResult">
                    <Grid Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1" CornerRadius="8" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind LatestTag}" FontSize="18" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Border Background="#0078D4" CornerRadius="4" Padding="6,2"
                                        Visibility="{x:Bind local:VersionPage.BoolToVisibility(IsLatest)}">
                                    <TextBlock Text="Latest" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#8A2BE2" CornerRadius="4" Padding="6,2"
                                        Visibility="{x:Bind local:VersionPage.BoolToVisibility(IsPreRelease)}">
                                    <TextBlock Text="Pre-release" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="GitHub Release" FontSize="12" Opacity="0.6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="リリースノート"
                                    Click="ReleaseNotes_Click"
                                    Tag="{x:Bind}"/>
                            <Button Content="このバージョンを適用"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="VersionApply_Click"
                                    Tag="{x:Bind}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="True"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
    </Grid>
</Page>
