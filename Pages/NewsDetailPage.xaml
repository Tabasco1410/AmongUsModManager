<Page
    x:Class="AmongUsModManager.Pages.NewsDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid Padding="32">
        <ScrollViewer x:Name="TextScrollViewer">
            <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left">
                <Button Content="← 戻る" Click="BackButton_Click" Style="{StaticResource TextBlockButtonStyle}"/>
                <TextBlock x:Name="TitleText" FontSize="32" FontWeight="Bold" TextWrapping="Wrap"/>
                <TextBlock x:Name="DateText" Foreground="Gray"/>
                <MenuFlyoutSeparator/>

                
                <TextBlock x:Name="ContentText" FontSize="16" TextWrapping="Wrap" LineHeight="28"
                           Visibility="Collapsed"/>

                
                <ItemsControl x:Name="ImageList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border CornerRadius="8" Margin="0,8,0,0" MaxWidth="700">
                                <Image Source="{x:Bind}" Stretch="Uniform" HorizontalAlignment="Left"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        
        
        <Grid x:Name="WebViewContainer" Visibility="Collapsed" Padding="0,120,0,0">
            <StackPanel Spacing="0">
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                    <Button Content="← 戻る" Click="BackButton_Click" Style="{StaticResource TextBlockButtonStyle}"/>
                    <StackPanel>
                        <TextBlock x:Name="WebTitleText" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="WebDateText" Foreground="Gray" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
                <controls:WebView2 x:Name="ContentWebView" MinHeight="600"/>
            </StackPanel>
        </Grid>

        
        <ProgressRing x:Name="LoadingRing" IsActive="False" Width="48" Height="48"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Page>
