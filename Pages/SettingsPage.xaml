<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AmongUsModManager.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AmongUsModManager.Models"
    xmlns:local="using:AmongUsModManager.Pages"
    x:DataType="local:SettingsPage"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <InfoBar x:Name="UnsavedChangesBar"
                 Grid.Row="0"
                 Title="未保存の変更があります"
                 Message="ページを離れる前に設定を保存しますか？"
                 IsOpen="False"
                 Severity="Warning">
            <InfoBar.ActionButton>
                <Button Content="保存して移動" Click="SaveAndExit_Click" Style="{StaticResource AccentButtonStyle}"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <ScrollViewer Grid.Row="1" Margin="24,0,24,0">
            <StackPanel Spacing="0" MaxWidth="820" HorizontalAlignment="Stretch">
                <TextBlock Text="設定" FontSize="28" FontWeight="SemiBold" Margin="0,24,0,20"/>

                <!-- ━━━ ゲームフォルダ ━━━ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE838;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="ゲームフォルダ" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="AmongUsが入っているフォルダを登録してください。複数のプラットフォームを登録できます。"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

                        <ListView x:Name="VanillaPathListView" ItemsSource="{x:Bind VanillaPaths}"
                                  SelectionMode="None" BorderThickness="1"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="6">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:VanillaPathInfo">
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="12" ColumnSpacing="12">
                                        <TextBox Text="{x:Bind Name, Mode=TwoWay}" Width="150" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Path}" Foreground="Gray"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="2" Content="削除" Click="RemovePath_Click" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- 自動検出 -->
                        <Expander Header="Among Usを自動検出する" Padding="0,8">
                            <StackPanel Spacing="10" Padding="0,8,0,4">
                                <TextBlock Text="指定がない場合はすべてのドライブをスキャンします"
                                           FontSize="12" Foreground="Gray"/>
                                <Grid ColumnDefinitions="*, Auto" MaxWidth="520" HorizontalAlignment="Left">
                                    <TextBox x:Name="ScanTargetTextBox" PlaceholderText="スキャンするフォルダを選択（省略可）"
                                             IsReadOnly="True" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="場所を選択" Click="SelectScanTarget_Click" Margin="8,0,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="スキャン開始" Click="ScanDrives_Click" Style="{StaticResource AccentButtonStyle}"/>
                                    <Button Content="パスをクリア" Click="ClearScanTarget_Click"/>
                                    <Button x:Name="AddAllButton" Content="すべて追加" Click="AddAllDetected_Click" IsEnabled="False"/>
                                </StackPanel>
                                <ListView x:Name="DetectedPathListView" ItemsSource="{x:Bind DetectedPaths}"
                                          MaxHeight="160" BorderThickness="1"
                                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="4">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid ColumnDefinitions="*, Auto" Padding="8">
                                                <TextBlock Text="{x:Bind}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="追加" Click="AddDetectedSingle_Click" Tag="{x:Bind}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ━━━ メインプラットフォーム ━━━ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7FC;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="メインプラットフォーム" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="購入・プレイしているプラットフォームを選択してください。起動方法やフォルダ検出に使用されます。"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon x:Name="MainPlatformIcon" Glyph="&#xE7FC;" FontSize="20"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="現在のメインプラットフォーム"
                                           FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="MainPlatformLabel" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="PlatformSwitchPanel" Spacing="8"/>
                        <TextBlock x:Name="PlatformSwitchHint"
                                   Text="複数のフォルダを登録するとここで切り替えられます。"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- ━━━ Modインストール先 ━━━ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8B7;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Modインストール先フォルダ" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Modのコピー先フォルダを変更できます。通常はゲームフォルダと同じです。"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*, Auto" MaxWidth="560" HorizontalAlignment="Left">
                            <TextBox x:Name="ModDataPathTextBox" IsReadOnly="True" Grid.Column="0" VerticalAlignment="Center"/>
                            <Button Content="変更" Click="ChangeModPath_Click" Grid.Column="1" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ━━━ 起動・常駐設定 ━━━ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE823;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="起動・常駐設定" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ToggleSwitch x:Name="StartWithWindowsToggle"
                                      Header="Windows起動時に自動で起動する"
                                      Toggled="StartWithWindowsToggle_Toggled"/>
                        <ToggleSwitch x:Name="StartMinimizedToggle"
                                      Header="起動時にバックグラウンド（トレイ）で起動する"
                                      IsEnabled="{x:Bind StartWithWindowsToggle.IsOn, Mode=OneWay}"/>
                        <ToggleSwitch x:Name="MinimizeToTrayToggle"
                                      Header="閉じるボタンでウィンドウを閉じずにトレイに格納する"
                                      Toggled="MinimizeToTrayToggle_Toggled"/>
                        <TextBlock Text="トレイアイコンを右クリックすることでメニューが表示されます。「終了」を選択するとアプリを完全に終了します。"
                                   FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{x:Bind MinimizeToTrayToggle.IsOn, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <!-- ━━━ Epic Games ━━━ -->
                <Border x:Name="EpicSettingsSection"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE83B;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Epic Games 設定" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock x:Name="CurrentPlatformText" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="EpicStatusIcon" Glyph="&#xE7BA;" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="EpicStatusText" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="🚀 Epic Games Launcher を開く" Click="EpicOpenLauncher_Click" Padding="12,6"/>
                                    <Button Content="🔄 状態を再確認" Click="EpicRecheck_Click" Padding="12,6"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <ToggleSwitch x:Name="EpicLaunchViaLauncherToggle"
                                      Header="Among Us をランチャー経由で起動する（推奨）"
                                      Toggled="EpicLaunchViaLauncherToggle_Toggled"/>
                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            ランチャー経由で起動すると EOS 認証が通り、オンラインマッチメイキングや実績が正常に動作します。
                            OFFにすると直接 exe を起動します（オフライン専用Modプレイ向け）。
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ━━━ ログ設定 ━━━ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D9;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="ログ設定" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="LogOutput_*.log は設定ファイルと同じフォルダに出力されます"
                                   FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="ログモード" FontSize="12" FontWeight="SemiBold"/>
                        <StackPanel Spacing="8">
                            <RadioButton x:Name="LogOverwriteRadio"
                                         Content="起動ごとに上書き（LogOutput.log 1ファイル）"
                                         GroupName="LogMode"
                                         Checked="LogMode_Checked"/>
                            <RadioButton x:Name="LogNewFileRadio"
                                         Content="起動ごとに新しいファイルを作成（最大10件保持）"
                                         GroupName="LogMode"
                                         Checked="LogMode_Checked"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ━━━ 通知設定 ━━━ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7E7;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="通知設定" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Windowsのトースト通知（右下ポップアップ）で通知します。"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <ToggleSwitch x:Name="NotifyModUpdateToggle"
                                      Header="Modの更新があったとき通知する"
                                      Toggled="NotifyToggle_Toggled"/>
                        <ToggleSwitch x:Name="NotifyAppUpdateToggle"
                                      Header="アプリ本体の更新があったとき通知する"
                                      Toggled="NotifyToggle_Toggled"/>
                        <ToggleSwitch x:Name="NotifyNewsToggle"
                                      Header="新しいお知らせがあったとき通知する"
                                      Toggled="NotifyToggle_Toggled"/>
                    </StackPanel>
                </Border>

                <!-- ━━━ 外観 ━━━ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE790;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="外観" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="テーマ" FontSize="12" FontWeight="SemiBold"/>
                        <StackPanel Spacing="8">
                            <RadioButton x:Name="ThemeDefaultRadio"
                                         Content="システム設定に合わせる"
                                         GroupName="Theme"
                                         Checked="Theme_Checked"/>
                            <RadioButton x:Name="ThemeDarkRadio"
                                         Content="ダークモード"
                                         GroupName="Theme"
                                         Checked="Theme_Checked"/>
                            <RadioButton x:Name="ThemeLightRadio"
                                         Content="ライトモード"
                                         GroupName="Theme"
                                         Checked="Theme_Checked"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                
                <StackPanel Spacing="8" Margin="0,8,0,40">
                    <Button x:Name="SaveButton" Content="設定を保存" Click="SaveButton_Click"
                            Style="{StaticResource AccentButtonStyle}" Width="160"/>
                    <TextBlock x:Name="StatusMessage" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
