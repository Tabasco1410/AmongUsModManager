<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AmongUsModManager.Pages.NotificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AmongUsModManager.Pages"
    xmlns:models="using:AmongUsModManager.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <Page.Resources>
        <models:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
        <models:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="28,20,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="お知らせ" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock x:Name="SubtitleText"
                           Text="読み込み中..."
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressRing x:Name="LoadingRing" IsActive="True" Width="20" Height="20"/>
                <Button Content="更新" Click="Refresh_Click"/>
                <Button Content="すべて既読" Click="MarkAllNewsRead_Click"/>
            </StackPanel>
        </Grid>

        
        <TabView Grid.Row="1"
                 TabWidthMode="Equal"
                 IsAddTabButtonVisible="False">

            
            <TabViewItem Header="📢 アプリからのお知らせ" IsClosable="False">
                <Grid>
                    <ListView x:Name="NewsListView"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="NewsItem_Click">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,3"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:NotificationNewsItem">
                                <Border Padding="16,14" CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                                        
                                        <Ellipse Width="9" Height="9" VerticalAlignment="Top" Margin="0,5,0,0"
                                                 Fill="{x:Bind UnreadDotColor}"/>

                                        
                                        <StackPanel Grid.Column="1" Spacing="5">
                                            <StackPanel Orientation="Horizontal" Spacing="8" FlowDirection="LeftToRight">
                                                <TextBlock Text="{x:Bind Title}"
                                                           FontSize="16" FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                <Border Background="DodgerBlue" CornerRadius="8" Padding="6,1"
                                                        Visibility="{x:Bind IsUnread, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="NEW" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="SeaGreen" CornerRadius="8" Padding="6,1"
                                                        Visibility="{x:Bind HasImages, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="📷 画像あり" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind PreviewContent}"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap" MaxLines="2"
                                                       Opacity="{x:Bind ContentOpacity}"/>
                                            <TextBlock Text="{x:Bind Date}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>

                                        
                                        <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center">
                                            <Button Content="詳細を見る"
                                                    Click="ViewDetail_Click" Tag="{x:Bind}"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    FontSize="13" Padding="12,6"/>
                                            <Button Content="既読にする"
                                                    Click="MarkReadBtn_Click" Tag="{x:Bind}"
                                                    FontSize="13" Padding="12,6"
                                                    Visibility="{x:Bind IsUnread, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock x:Name="NewsEmptyText"
                               Text="お知らせはありません"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </TabViewItem>

            
            <TabViewItem IsClosable="False">
                <TabViewItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🔔 アプリ内通知" VerticalAlignment="Center"/>
                        <Border x:Name="AppNotifBadge" Background="Red" CornerRadius="8"
                                MinWidth="18" Height="18" Padding="3,0"
                                Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock x:Name="AppNotifCount" Text="0" FontSize="10"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </TabViewItem.Header>

                <Grid>
                    <ListView x:Name="AppNotifListView" SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,3"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AppNotifDisplayItem">
                                <Border Padding="16,12" CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                        
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="{x:Bind KindColor}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind KindIcon}"
                                                       FontSize="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Message}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind TimeText}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>

                                        <Ellipse Grid.Column="2" Width="8" Height="8"
                                                 Fill="{x:Bind UnreadDotColor}"
                                                 VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock x:Name="AppNotifEmptyText"
                               Text="アプリ内通知はありません"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </TabViewItem>

        </TabView>
    </Grid>
</Page>
