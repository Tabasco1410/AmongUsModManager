<Page
    x:Class="AmongUsModManager.Pages.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            
            <RowDefinition Height="Auto"/>
            
        </Grid.RowDefinitions>

        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="20" Width="520" Margin="0,40,0,24">

                
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <Image Source="/Resource/Icon.png" Width="56" Height="56"
                           HorizontalAlignment="Center"/>
                    <TextBlock Text="AmongUsModManager へようこそ"
                               FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="はじめに Among Us のインストールフォルダを指定してください"
                               FontSize="13" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="① 購入・プレイしたプラットフォームを選択"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <ComboBox x:Name="PlatformCombo"
                                  PlaceholderText="プラットフォームを選択してください"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="PlatformCombo_SelectionChanged">
                            <ComboBoxItem Content="Steam"            Tag="Steam"/>
                            <ComboBoxItem Content="Epic Games"       Tag="Epic"/>
                            <ComboBoxItem Content="Microsoft Store"  Tag="MSStore"/>
                            <ComboBoxItem Content="itch.io"          Tag="Itch"/>
                            <ComboBoxItem Content="手動でフォルダを指定" Tag="Manual"/>
                        </ComboBox>

                        
                        <TextBlock x:Name="PlatformHint"
                                   Text=""
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="② Among Us のインストールフォルダを指定"
                                   FontSize="13" FontWeight="SemiBold"/>

                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap">
                            「Among Us.exe」が入っているフォルダを指定してください。
                        </TextBlock>

                        
                        <Button x:Name="AutoDetectButton"
                                Content="🔍 自動検出"
                                HorizontalAlignment="Stretch"
                                IsEnabled="False"
                                Click="AutoDetectButton_Click"
                                Style="{StaticResource AccentButtonStyle}"/>

                        
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                            <TextBox x:Name="PathTextBox"
                                     PlaceholderText="フォルダのパスがここに表示されます"
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="参照..."
                                    Click="BrowseButton_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        
                        <InfoBar x:Name="ValidateInfoBar"
                                 IsOpen="False"
                                 IsClosable="False"/>
                    </StackPanel>
                </Border>

                
                <Border x:Name="EpicLoginPanel"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16"
                        Visibility="Collapsed">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Epic Games ログイン状態"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon x:Name="EpicStatusIcon" Glyph="&#xE7BA;" FontSize="18"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="EpicStatusText"
                                       Text=""
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            Epic版のオンライン機能を使うには Epic Games Launcher 経由での起動が必要です。
                            セットアップ後もランチャー経由で起動することを推奨します。
                        </TextBlock>
                        <Button x:Name="EpicLaunchLauncherBtn"
                                Content="🚀 Epic Games Launcher を起動"
                                Click="EpicLaunchLauncher_Click"
                                Visibility="Collapsed"
                                Padding="12,6"/>
                    </StackPanel>
                </Border>

                
                <Border x:Name="NotFoundPanel"
                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16"
                        Visibility="Collapsed">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7BA;" FontSize="16"
                                      Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                            <TextBlock Text="Among Us が見つかりませんでした"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            インストール先が正しいか確認してください。Among Us.exe が含まれているフォルダを「参照...」から直接指定することもできます。
                            まだ Among Us をお持ちでない場合は、以下からインストール後に再度「自動検出」をお試しください。
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Steam で入手"      Click="OpenSteamStore_Click" Padding="12,6"/>
                            <Button Content="Epic Games で入手" Click="OpenEpicStore_Click"  Padding="12,6"/>
                            <Button Content="itch.io で入手"    Click="OpenItchStore_Click"  Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                
                <Button x:Name="FinishButton"
                        Content="セットアップ完了"
                        HorizontalAlignment="Stretch"
                        Height="46"
                        IsEnabled="False"
                        Click="FinishButton_Click"
                        Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>
        </ScrollViewer>

        
        <Border Grid.Row="1"
                Background="{ThemeResource NavigationViewDefaultPaneBackground}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               Text="フォルダが見つからない・エラーが出る場合"/>
                    <TextBlock FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap">
                        「参照...」でフォルダを直接指定するか、Discord でお問い合わせください。
                    </TextBlock>
                </StackPanel>

                
                <Button Grid.Column="1"
                        Content="Steam で入手"
                        Click="OpenSteamStore_Click"
                        Padding="12,6"
                        VerticalAlignment="Center"/>

                
                <Button Grid.Column="2"
                        Content="Epic で入手"
                        Click="OpenEpicStore_Click"
                        Padding="12,6"
                        VerticalAlignment="Center"/>

                
                <Button Grid.Column="3"
                        Content="itch.io で入手"
                        Click="OpenItchStore_Click"
                        Padding="12,6"
                        VerticalAlignment="Center"/>

                
                <Button Grid.Column="4"
                        Content="Discord サポート"
                        Click="OpenDiscordSupport_Click"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground">#5865F2</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver">#4752C4</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed">#3C45A5</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForeground">White</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver">White</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForegroundPressed">White</SolidColorBrush>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Page>
