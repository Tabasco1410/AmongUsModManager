<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AmongUsModManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AmongUsModManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AmongUsModManager">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- タイトルバー -->
        <Grid Grid.Row="0" Height="48"
              IsHitTestVisible="False"
              Background="{ThemeResource NavigationViewDefaultPaneBackground}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid Margin="16,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">                    
                    <TextBlock x:Name="AppTitleText" Text="AmongUsModManager"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right" Spacing="8">
                    <TextBlock x:Name="VersionText" Text="" VerticalAlignment="Center" Opacity="0.8"/>
                    <Border x:Name="PreReleaseIcon" Visibility="Collapsed" Background="#FFDD9933"
                            CornerRadius="4" VerticalAlignment="Center">
                        <TextBlock Text="PRE" Padding="6,2" FontSize="11"/>
                    </Border>
                    <Border x:Name="DebugIcon" Visibility="Collapsed" Background="#FF5577CC"
                            CornerRadius="4" VerticalAlignment="Center">
                        <TextBlock Text="Debug" Padding="6,2" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        SelectionChanged="NavView_SelectionChanged"
                        OpenPaneLength="200">

            <NavigationView.PaneHeader>
                <StackPanel Margin="16,8,16,4" Spacing="6">
                    <!-- アップデートボタン -->
                    <Button x:Name="AppUpdatePaneBtn"
                            Content="アップデート"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed"
                            Click="AppUpdatePaneBtn_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            FontSize="12"/>
                    <!-- テーマ切替ボタン -->
                    <Button x:Name="ThemeToggleBtn"
                            HorizontalAlignment="Stretch"
                            Click="ThemeToggleBtn_Click"
                            FontSize="12"
                            Padding="8,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="ThemeIcon" Glyph="&#xE708;" FontSize="13"/>
                            <TextBlock x:Name="ThemeLabel" Text="ダークモード"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeItem" Content="ホーム" Tag="Home">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="ModInstallItem" Content="インストール" Tag="ModInstall">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE7BF;"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="LibraryItem" Content="Modライブラリ" Tag="Library">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8B1;"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- お知らせ（バッジ付き） -->
                <NavigationViewItem Tag="Notification">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xEA8F;"/></NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <Grid>
                            <TextBlock Text="お知らせ" VerticalAlignment="Center"/>
                            <Border x:Name="NotifSidebarBadge"
                                    Background="Red" CornerRadius="8"
                                    MinWidth="16" Height="16"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-2,-4,0" Padding="3,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="NotifSidebarCount" Text="0"
                                           FontSize="10" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </NavigationViewItem.Content>
                </NavigationViewItem>

                <NavigationViewItem Content="問い合わせ" Tag="Contact">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE939;"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="サポート" Tag="ChatBot">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F2;"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="DiscordNavItem" Tag="Discord">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" Foreground="#5865F2"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="Discord🔗" VerticalAlignment="Center"/>
                    </NavigationViewItem.Content>
                </NavigationViewItem>

                <NavigationViewItemSeparator x:Name="NavSeparator"/>

                <NavigationViewItem Content="データ管理" Tag="DataManagement">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9F5;"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- 競合チェック -->
                <NavigationViewItem Content="競合チェック" Tag="ConflictCheck">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9CE;"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="アプリについて" Tag="About">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE946;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="アカウント" Tag="Account">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE77B;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="設定" Tag="Settings">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
